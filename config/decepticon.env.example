# Decepticon configuration — copy to ~/.decepticon/.env on the deployed VM
# At least one LLM API key is required.

# ── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# ── Cloud-hosted models (optional) ───────────────────────────────────────────
AWS_BEDROCK_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_VERTEX_AI_PROJECT=
AZURE_OPENAI_ENDPOINT=

# ── Local models (optional) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=
LM_STUDIO_BASE_URL=

# ── Provider priority ─────────────────────────────────────────────────────────
# Comma-separated fallback order, e.g. "anthropic,openai,google"
DECEPTICON_AUTH_PRIORITY=

# ── Databases (change before deployment) ──────────────────────────────────────
POSTGRES_PASSWORD=changeme
NEO4J_PASSWORD=changeme

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Model profile: eco (low cost) | max (full capabilities) | test (CTF mode)
DECEPTICON_MODEL_PROFILE=max

# Interface language (default: en, 40+ languages supported)
DECEPTICON_LANGUAGE=en

# Auto-update on startup
AUTO_UPDATE=true

# ── Observability (optional) ──────────────────────────────────────────────────
LANGSMITH_API_KEY=
