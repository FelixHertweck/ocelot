# Decepticon configuration — copy to ~/.decepticon/.env on the deployed VM
# At least one LLM API key is required.

# ── Major providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=

# ── Inference / routing providers ─────────────────────────────────────────────
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=

# ── Asian providers ───────────────────────────────────────────────────────────
MOONSHOT_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=

# ── Cloud-hosted models (optional) ───────────────────────────────────────────
AWS_BEDROCK_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_VERTEX_AI_PROJECT=
AZURE_OPENAI_ENDPOINT=
AZURE_API_KEY=
AZURE_API_VERSION=

# ── OpenAI-compatible API ─────────────────────────────────────────────────────
# Use this for any endpoint that speaks the OpenAI API: vLLM, LocalAI,
# llama.cpp server, a cloud-hosted Ollama, or any other compatible backend.
# OPENAI_API_BASE overrides the base URL used with OPENAI_API_KEY.
# Example (local vLLM):  OPENAI_API_BASE=http://localhost:8000/v1
# Example (cloud Ollama): OPENAI_API_BASE=https://ollama.example.com/v1
OPENAI_API_BASE=

# ── Self-hosted / local models ────────────────────────────────────────────────
# Ollama — works for both local and remote instances.
# Example (local):  OLLAMA_BASE_URL=http://localhost:11434
# Example (remote): OLLAMA_BASE_URL=https://ollama.example.com
OLLAMA_BASE_URL=
LM_STUDIO_BASE_URL=

# ── Engagement ────────────────────────────────────────────────────────────────
# Set DECEPTICON_ENGAGEMENT_NAME to auto-generate the workspace (roe.md,
# conops.md) on first run via decepticon-start. Leave empty to skip.
DECEPTICON_ENGAGEMENT_NAME=

# Target IP ranges / subnets — comma-separated, e.g. 192.168.1.0/24,10.0.0.5
DECEPTICON_TARGET_RANGES=
# Target hostnames or URLs — comma-separated
DECEPTICON_TARGET_URLS=
# Explicitly out-of-scope targets — comma-separated
DECEPTICON_SCOPE_EXCLUDE=

# Threat actor profile: nation-state | financially-motivated | insider
DECEPTICON_THREAT_PROFILE=nation-state
# Noise level for OPSEC: low | medium | high
DECEPTICON_OPSEC_LEVEL=medium
# Main engagement objective (free text)
DECEPTICON_OBJECTIVE=
# Authorized by (name / role)
DECEPTICON_AUTHORIZED_BY=
# Testing window (free text, e.g. "2026-06-01 08:00 – 18:00 CEST")
DECEPTICON_TESTING_WINDOW=

# ── Provider priority ─────────────────────────────────────────────────────────
# Comma-separated fallback order, e.g. "anthropic,openai,google"
DECEPTICON_AUTH_PRIORITY=

# ── Databases (change before deployment) ──────────────────────────────────────
POSTGRES_PASSWORD=changeme
NEO4J_PASSWORD=changeme

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Model profile: eco (low cost) | max (full capabilities) | test (CTF mode)
DECEPTICON_MODEL_PROFILE=max

# Per-role model overrides (optional, override DECEPTICON_MODEL_PROFILE per agent)
DECEPTICON_MODEL_RECON=
DECEPTICON_MODEL_EXPLOIT=
DECEPTICON_MODEL_PRIVESC=
DECEPTICON_MODEL_LATERAL=
DECEPTICON_MODEL_C2=

# Interface language (default: en, 40+ languages supported)
DECEPTICON_LANGUAGE=en

# Auto-update on startup
AUTO_UPDATE=true

# ── Auto-create engagement on startup (optional) ─────────────────────────────
# When set, decepticon-start waits for the web service to be healthy and then
# calls POST /api/engagements automatically. Idempotent — safe to re-run.
# DECEPTICON_ENGAGEMENT_NAME must be 3-64 chars, lowercase alphanumeric + hyphens.
# DECEPTICON_ENGAGEMENT_TARGET_TYPE: ip_range | web_url
# DECEPTICON_ENGAGEMENT_TARGET_VALUE: the target (IP, CIDR, or URL)
# DECEPTICON_ENGAGEMENT_NAME=my-engagement
# DECEPTICON_ENGAGEMENT_TARGET_TYPE=ip_range
# DECEPTICON_ENGAGEMENT_TARGET_VALUE=10.0.0.0/24

# ── Ports (optional, change only if defaults conflict) ────────────────────────
WEB_PORT=3000
LANGGRAPH_PORT=2024
LITELLM_PORT=4000

# ── Remote access (set all three when the dashboard is reached from another host) ─
# The web chat/graph panels and the terminal connect from the BROWSER directly
# to LangGraph (:2024) and the terminal server (:3003) — there is no server-side
# proxy. Leave these blank/localhost for a purely local deployment.
#
#   NEXT_PUBLIC_* are baked into the Next.js bundle at build time, so changing
#   them requires re-running `decepticon-rebuild-web`.
#   TERMINAL_ALLOWED_ORIGINS is a runtime env (read by terminal-server.ts) — a
#   plain `decepticon-start` / container restart is enough.
#
# Replace <VM_IP> with the address the browser uses to load the dashboard.
# NEXT_PUBLIC_LANGGRAPH_API_URL=http://<VM_IP>:2024
# NEXT_PUBLIC_TERMINAL_WS_URL=ws://<VM_IP>:3003
# TERMINAL_ALLOWED_ORIGINS=http://<VM_IP>:3000

# ── Paths (optional) ──────────────────────────────────────────────────────────
# Override base config directory (default: ~/.decepticon)
DECEPTICON_HOME=

# ── Observability (optional) ──────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
