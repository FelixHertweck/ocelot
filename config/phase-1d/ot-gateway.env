# iptables routing rules applied by run.sh on VM startup.
# These values must match the CAVE virtual network CIDRs and the gateway's own
# IP on the IT-side network (net1).

# Attacker/IT network — net1 (10.1.1.0/24 per phase-1d.json5 firstOctet + id:1)
IT_NETWORK=10.1.1.0/24

# OT network — net2 (10.1.2.0/24 per phase-1d.json5 firstOctet + id:2)
OT_NETWORK=10.1.2.0/24

# Gateway's own IP on the IT-side network (lastOctet: 10, net1 → 10.1.1.10)
# Used to allow the gateway's own forwarded traffic (SSH tunnel sessions) into OT_NETWORK
GATEWAY_IP=10.1.1.10

# OT device registry — injected into /api/v1/ot/assets at container startup.
# Points to the inverter-emulator on the OT network (lastOctet: 15, net2 → 10.1.2.15).
OT_DEVICE_MODEL="SMA Sunny Tripower 15000TL-30"
# OT_DEVICE_IP=10.1.2.15
# OT_DEVICE_PORT=502
