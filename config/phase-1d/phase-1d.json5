{
  firstOctet: 10,
  wireguardCidr: "10.253.0.0/16",
  globalInstances: [
    {
      name: "vpn",
      type: "vpn-server",
      image: "vpn:latest",
      flavor: "server-small",
      hostname: "vpn",
      fqdn: "vpn.cave.lab",
    },
    {
      type: "dns-server",
      image: "dns:latest",
      name: "dns",
      flavor: "server-small",
      lastOctet: 254,
      hostname: "dns.cave.lab",
      fqdn: "dns.cave.lab",
    },
  ],
  labs: [
    {
      name: "phase-1d",
      times: 1,
      virtualNetworks: [
        {
          // Attacker network: openhands + ot-gateway HTTP/SSH interface
          internalDns: false,
          id: 1,
        },
        {
          // OT network: ot-gateway (OT-side NIC) + inverter-emulator
          internalDns: false,
          id: 2,
        },
      ],
      dnsConfig: [],
      instances: [
        {
          // OT management gateway — dual-homed jump host bridging both networks.
          type: "linux",
          image: "ot-management-gateway:latest",
          post: "ot-gateway",
          networks: [ 1, 2 ],
          lastOctet: 10,
          name: "ot-gateway",
          flavor: "server-small",
          hostname: "ot-gateway",
          configFiles: [
            { source: "/cave/backend/configs/phase-1d/ot-gateway.env", destination: "/home/ubuntu/.env" },
          ],
          postCommand: "/home/ubuntu/run.sh",
        },
        {
          // SMA inverter emulator — OT network only, directly reachable from the gateway.
          type: "linux",
          image: "inverter-emulator:latest",
          post: "inverter-emulator",
          networks: [ 2 ],
          lastOctet: 15,
          macAddress: null,
          name: "inverter-emulator",
          flavor: "server-small",
          hostname: "inverter-emulator",
          postCommand: "/home/ubuntu/run.sh",
        },
        {
          type: "linux",
          image: "openhands:latest",
          post: "openhands",
          networks: [ 1 ],
          lastOctet: 20,
          name: "openhands",
          // For larger instances, if want more conversations at a time use bigger flavor
          // flavor: "server-xlarge",
          flavor: "server-large",
          hostname: "openhands",
          configFiles: [
            { source: "/cave/backend/configs/phase-1d/openhands.env", destination: "/home/ubuntu/.env" },
            { source: "/cave/backend/configs/phase-1d/mcp-servers.json", destination: "/home/ubuntu/mcp-servers.json" },
          ],
          postCommand: "/home/ubuntu/run.sh",
        },
      ],
    },
  ],
}
