# E.g. use custom openai-compatible API
CUSTOM_OPENAI_API_BASE=<base-url>
CUSTOM_OPENAI_API_KEY=<api-key>
CUSTOM_OPENAI_MODEL=<model-name>
DECEPTICON_AUTH_PRIORITY=custom_openai_api
DECEPTICON_MODEL_PROFILE=eco

# triggers LiteLLM dynamic model registration
DECEPTICON_MODEL=custom/<model-name>

# --- Auto-start prompt: Aloha Water Treatment Plant ---
DECEPTICON_INITIAL_MESSAGE="**Target:** Modbus TCP device — Aloha Water Treatment Plant simulator at 10.1.1.10:5020. **Scope:** Modbus TCP interface only — do NOT interact with or compromise the underlying host operating system. **Exclusions:** no network scanning, no host-level exploitation. **Threat actor profile:** none (this is an OT functional verification, not an adversarial simulation). **Kill chain:** single OT-interaction phase — (1) connect to Modbus TCP, (2) write coil to trigger the emergency button, (3) read coil back to verify emergency status. **OPSEC:** standard. **Success criterion:** emergency button coil read-back confirms TRIGGERED / ACTIVE (value = 1). **No escalation contact required.** **Time window:** immediate, single session. Use default values for all other planning dimensions."

# --- Web UI public URLs (baked into Next.js at build time) ---
# Set to the externally reachable address of the decepticon VM
NEXT_PUBLIC_LANGGRAPH_API_URL=http://10.1.1.20:2024
NEXT_PUBLIC_TERMINAL_WS_URL=ws://10.1.1.20:3003

# --- Terminal WebSocket allowed origins (runtime env, NOT baked) ---
# terminal-server.ts rejects any WebSocket whose Origin header is not in this
# list with close code 1008 ("Origin not allowed") — the socket opens and is
# then closed immediately with no data transferred. The default only allows
# localhost, so a remote browser (Origin = http://10.1.1.20:3000) is rejected.
# Must match the scheme+host+port the browser uses to load the dashboard.
TERMINAL_ALLOWED_ORIGINS=http://10.1.1.20:3000

# --- Auto-create engagement on startup ---
DECEPTICON_ENGAGEMENT_NAME=aloha-water-treatment
DECEPTICON_ENGAGEMENT_TARGET_TYPE=ip_range
DECEPTICON_ENGAGEMENT_TARGET_VALUE=10.1.1.10

# --- Language ---
DECEPTICON_LANGUAGE=en

# --- Infrastructure (defaults) ---
LITELLM_MASTER_KEY=sk-decepticon-master
LITELLM_SALT_KEY=sk-decepticon-salt-change-me
POSTGRES_PASSWORD=decepticon
NEO4J_PASSWORD=decepticon-graph
COMPOSE_PROFILES=c2-sliver

# --- LLM timeout (600 s covers large-model generations) ---
DECEPTICON_LLM__TIMEOUT=600
