# --- LLM Provider ---
LLM_MODEL=<model-name>
LLM_API_KEY=<api-key>
LLM_BASE_URL=<base-url>

# --- Task ---
OPENHANDS_TASK=''

# --- Search ---
# Tavily API Key for web search tool
# TAVILY_API_KEY=<api-key>

# --- Neo4j MCP ---
# Change optional default password
# Min. 8 characters required for NEO4J_PASSWORD
# NEO4J_PASSWORD=<password>
# Set to false to disable the Neo4j MCP server
# NEO4J_MCP_ENABLED=true

# --- Host IP ---
# used by OpenHands to configure CORS for remote browser access
HOST_IP=10.1.1.20
