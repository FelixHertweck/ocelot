{
  firstOctet: 10,
  wireguardCidr: "10.253.0.0/16",
  globalInstances: [
    {
      name: "vpn",
      type: "vpn-server",
      image: "vpn:latest",
      flavor: "server-small",
      hostname: "vpn",
      fqdn: "vpn.cave.lab",
    },
    {
      type: "dns-server",
      image: "dns:latest",
      name: "dns",
      flavor: "server-small",
      lastOctet: 254,
      hostname: "dns.cave.lab",
      fqdn: "dns.cave.lab",
    },
  ],
  labs: [
    {
      name: "phase-1b",
      times: 1,
      virtualNetworks: [
        {
          // Attacker network: openhands + ot-gateway HTTP/SSH interface
          internalDns: false,
          id: 1,
        },
        {
          // OT network: ot-gateway (OT-side NIC) + ot-proxy + physical OT device
          internalDns: false,
          id: 2,
        },
      ],
      dnsConfig: [],
      instances: [
        {
          // OT management gateway — dual-homed jump host bridging both networks.
          // Exposes an HTTP admin interface (default credentials) on net1 and
          // has routing access to the OT network (net2) for Modbus TCP interaction.
          type: "linux",
          image: "ot-management-gateway:latest",
          post: "ot-gateway",
          networks: [ 1, 2 ],
          lastOctet: 10,
          name: "ot-gateway",
          flavor: "server-small",
          hostname: "ot-gateway",
          configFiles: [
            { source: "/cave/backend/configs/phase-1b/ot-gateway.env", destination: "/home/ubuntu/.env" },
          ],
          postCommand: "/home/ubuntu/run.sh",
        },
        {
          // Modbus TCP security proxy — OT network only, sits between the gateway
          // and the upstream physical OT device.
          type: "linux",
          image: "ot-proxy:latest",
          post: "ot-proxy",
          networks: [ 2 ],
          lastOctet: 15,
          macAddress: null,
          name: "ot-proxy",
          flavor: "server-small",
          hostname: "ot-proxy",
          configFiles: [
            { source: "/cave/backend/configs/phase-1b/proxy-config.yml", destination: "/home/ubuntu/proxy-config.yml" },
            { source: "/cave/backend/configs/phase-1b/ot-proxy.env", destination: "/home/ubuntu/.env" },
          ],
          postCommand: "/home/ubuntu/run.sh",
        },
        {
          // AI-driven attacker — attacker network only, no direct OT network access.
          type: "linux",
          image: "openhands:latest",
          post: "openhands",
          networks: [ 1 ],
          lastOctet: 20,
          name: "openhands",
          flavor: "server-large",
          hostname: "openhands",
          configFiles: [
            { source: "/cave/backend/configs/phase-1b/openhands.env", destination: "/home/ubuntu/.env" },
            { source: "/cave/backend/configs/phase-1b/mcp-servers.json", destination: "/home/ubuntu/mcp-servers.json" },
          ],
          postCommand: "/home/ubuntu/run.sh",
        },
      ],
    },
  ],
}
