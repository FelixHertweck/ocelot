# ── LLM provider ──────────────────────────────────────────────────────────────
# Add your LLM provider here (check decepticon.env.example for details)

# ── Engagement ────────────────────────────────────────────────────────────────
DECEPTICON_ENGAGEMENT_NAME=aloha-water-treatment

DECEPTICON_TARGET_RANGES=
DECEPTICON_TARGET_URLS=

DECEPTICON_THREAT_PROFILE=nation-state
DECEPTICON_OPSEC_LEVEL=medium
DECEPTICON_OBJECTIVE=The target is a Modbus TCP device (Aloha Water Treatment plant simulator). The objective is not to compromise the host system. Instead, interact with the Modbus interface to turn on the pump, then verify the pump status. The mission is complete when the pump is confirmed to be running.

# ── Databases ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
NEO4J_PASSWORD=changeme
