{
  firstOctet: 10,
  wireguardCidr: "10.253.0.0/16",
  globalInstances: [
    {
      name: "vpn",
      type: "vpn-server",
      image: "vpn:latest",
      flavor: "server-small",
      hostname: "vpn",
      fqdn: "vpn.cave.lab",
    },
    {
      type: "dns-server",
      image: "dns:latest",
      name: "dns",
      flavor: "server-small",
      lastOctet: 254,
      hostname: "dns.cave.lab",
      fqdn: "dns.cave.lab",
    },
  ],
  labs: [
    {
      name: "decepticon-vs-aloha",
      times: 1,
      virtualNetworks: [
        {
          internalDns: false,
          id: 1,
        },
      ],
      dnsConfig: [],
      instances: [
        {
          type: "linux",
          image: "aloha-water-treatment:latest",
          networks: [ 1 ],
          lastOctet: 10,
          name: "aloha-water-treatment",
          flavor: "server-small",
          hostname: "aloha-water-treatment",
          postCommand: "sudo systemctl restart aloha-plc.service aloha-hmi.service",
        },
        {
          type: "linux",
          image: "decepticon:latest",
          networks: [ 1 ],
          lastOctet: 20,
          name: "decepticon",
          flavor: "server-large",
          hostname: "decepticon",
          postCommand: "bash ~/set-targets.sh && decepticon-start",
        },
      ],
    },
  ],
}
